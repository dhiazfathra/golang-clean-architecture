func TestHandler_Delete_Returns404WhenNotFound(t *testing.T) {
	store := &mockEventStore{
		LoadFn: func(_ context.Context, _, _ string, _ int) ([]eventstore.Event, error) {
			return nil, nil
		},
	}
	h := newTestHandler(store, &mockReadRepo{})

	c, rec := echoCtx(http.MethodDelete, "/{{.NamePlural}}/99", "")
	c.SetParamNames("id")
	c.SetParamValues("99")
	c.Set("user_id", "actor1")

	err := h.Delete(c)
	require.NoError(t, err)
	assert.Equal(t, http.StatusNotFound, rec.Code)
}

func TestHandler_Delete_Returns200WhenSuccess(t *testing.T) {
	var deletedID string
	store := &mockEventStore{
		LoadFn: func(_ context.Context, _, id string, _ int) ([]eventstore.Event, error) {
			return []eventstore.Event{createdEvent(id)}, nil
		},
		AppendFn: func(_ context.Context, events []eventstore.Event) error {
			if len(events) > 0 {
				deletedID = events[0].AggregateID()
			}
			return nil
		},
	}
	h := newTestHandler(store, &mockReadRepo{})

	c, rec := echoCtx(http.MethodDelete, "/{{.NamePlural}}/1", "")
	c.SetParamNames("id")
	c.SetParamValues("1")
	c.Set("user_id", "actor1")

	err := h.Delete(c)
	require.NoError(t, err)
	assert.Equal(t, http.StatusOK, rec.Code)
	assert.Equal(t, "1", deletedID)
}
