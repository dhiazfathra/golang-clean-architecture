# OpenAPI 3.x path fragment for the {{.NameTitle}} module.
# Generated by: make generate module={{.Name}} fields=...
# Merge into api/openapi.yaml under the `paths:` key.
# Also add {{.NameTitle}}ReadModel, Create{{.NameTitle}}Request, Update{{.NameTitle}}Request
# to the `components.schemas` section.

  /{{.NamePlural}}:
    post:
      tags: [{{.NameTitle}}]
      summary: Create {{.NameTitle}}
      security:
        - sessionCookie: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Create{{.NameTitle}}Request'
      responses:
        '201':
          description: Created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{.NameTitle}}ReadModel'
        '400': {$ref: '#/components/responses/BadRequest'}
        '401': {$ref: '#/components/responses/Unauthorized'}
        '403': {$ref: '#/components/responses/Forbidden'}
        '500': {$ref: '#/components/responses/InternalServerError'}
    get:
      tags: [{{.NameTitle}}]
      summary: List {{.NameTitle}}s
      security:
        - sessionCookie: []
      parameters:
        - {name: page,      in: query, schema: {type: integer, default: 1}}
        - {name: page_size, in: query, schema: {type: integer, default: 20}}
        - {name: sort_by,   in: query, schema: {type: string, enum: [created_at, updated_at]}}
        - {name: sort_dir,  in: query, schema: {type: string, enum: [asc, desc]}}
      responses:
        '200':
          description: Paginated list
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{.NameTitle}}ListResponse'
        '401': {$ref: '#/components/responses/Unauthorized'}
        '403': {$ref: '#/components/responses/Forbidden'}

  /{{.NamePlural}}/{id}:
    get:
      tags: [{{.NameTitle}}]
      summary: Get {{.NameTitle}} by ID
      security:
        - sessionCookie: []
      parameters:
        - {name: id, in: path, required: true, schema: {type: string}}
      responses:
        '200':
          description: Found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{.NameTitle}}ReadModel'
        '401': {$ref: '#/components/responses/Unauthorized'}
        '403': {$ref: '#/components/responses/Forbidden'}
        '404': {$ref: '#/components/responses/NotFound'}
    put:
      tags: [{{.NameTitle}}]
      summary: Update {{.NameTitle}}
      security:
        - sessionCookie: []
      parameters:
        - {name: id, in: path, required: true, schema: {type: string}}
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Update{{.NameTitle}}Request'
      responses:
        '200': {description: Updated}
        '400': {$ref: '#/components/responses/BadRequest'}
        '401': {$ref: '#/components/responses/Unauthorized'}
        '403': {$ref: '#/components/responses/Forbidden'}
        '404': {$ref: '#/components/responses/NotFound'}
    delete:
      tags: [{{.NameTitle}}]
      summary: Delete {{.NameTitle}} (soft)
      security:
        - sessionCookie: []
      parameters:
        - {name: id, in: path, required: true, schema: {type: string}}
      responses:
        '204': {description: Deleted}
        '401': {$ref: '#/components/responses/Unauthorized'}
        '403': {$ref: '#/components/responses/Forbidden'}
        '404': {$ref: '#/components/responses/NotFound'}

