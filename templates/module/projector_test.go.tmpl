package {{.Name}}

import (
	"context"
	"testing"
	"time"

	sqlmock "github.com/DATA-DOG/go-sqlmock"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"

	"{{.ModPath}}/pkg/platform/eventstore"
	"{{.ModPath}}/pkg/platform/testutil"
)

// unknownEvent is a test-only event type not handled by the projector.
type unknownEvent struct{}

func (u *unknownEvent) AggregateID() string        { return "x" }
func (u *unknownEvent) AggregateType() string      { return "unknown" }
func (u *unknownEvent) EventType() string           { return "unknown.event" }
func (u *unknownEvent) Version() int                { return 1 }
func (u *unknownEvent) Timestamp() time.Time        { return time.Time{} }
func (u *unknownEvent) Metadata() map[string]string { return nil }

func TestProjector_Name(t *testing.T) {
	p := NewProjector(nil)
	assert.Equal(t, "{{.Name}}", p.Name())
}

func TestProjector_Handle_UnknownEventReturnsNil(t *testing.T) {
	// nil db is safe because the unknown event falls through to the default branch.
	p := NewProjector(nil)
	err := p.Handle(context.Background(), &unknownEvent{})
	require.NoError(t, err, "unrecognised event types must be silently ignored (return nil)")
}

func TestProjector_Handle_Created(t *testing.T) {
	db, mock := testutil.NewMockDB(t)
	p := NewProjector(db)

	mock.ExpectExec("INSERT INTO {{.Name}}_read").
		WillReturnResult(sqlmock.NewResult(1, 1))

	ev := &{{.NameTitle}}Created{
		BaseEvent: eventstore.NewBaseEvent("1", "{{.Name}}", "{{.Name}}.created", 1,
			map[string]string{"user_id": "u1"}),
	}
	require.NoError(t, p.Handle(context.Background(), ev))
	require.NoError(t, mock.ExpectationsWereMet())
}

