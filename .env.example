# ──────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────
# TCP address the server listens on (default: :8080)
LISTEN_ADDR=:8080

# Runtime environment: development | staging | production
# Controls: API docs visibility, log level, tracer behavior
# Keep in mind that API docs http://localhost:8080/docs will be visible in development and staging, but not in production
ENV=development

# Service name used in Datadog APM, logs, and metrics
# SERVICE_NAME=golang-clean-arch

# ──────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────
# Required. Full DSN including sslmode.
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable

# Connection pool tuning
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5

# ──────────────────────────────────────────────────
# Session Store (Valkey / Redis)
# ──────────────────────────────────────────────────
# Required. Host:port format.
VALKEY_URL=localhost:6379

# Session time-to-live (Go duration string, default: 24h)
# SESSION_TTL=24h

# ──────────────────────────────────────────────────
# Seeder Passwords
# ──────────────────────────────────────────────────
# Required for initial seeding.
SEED_SUPER_ADMIN_PASSWORD=changeme
SEED_DEFAULT_MODULE_PASSWORD=changeme

# Per-module overrides (optional):
# SEED_RBAC_ADMIN_PASSWORD=
# SEED_USER_ADMIN_PASSWORD=
# SEED_ORDER_ADMIN_PASSWORD=

# ──────────────────────────────────────────────────
# Snowflake ID Generation
# ──────────────────────────────────────────────────
# Node ID for distributed ID generation (1–1023, default: 1)
# SNOWFLAKE_NODE_ID=1

# ──────────────────────────────────────────────────
# Observability (Datadog)
# ──────────────────────────────────────────────────
# Optional. If unset, tracer/profiler run in no-op mode.
# DD_API_KEY=

# Log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info

# StatsD agent address (default: localhost:8125)
# STATSD_ADDR=localhost:8125

# Metric namespace prefix (default: golang_clean_arch.)
# STATSD_NAMESPACE=golang_clean_arch.

# ──────────────────────────────────────────────────
# Testing (used by testutil, not production)
# ──────────────────────────────────────────────────
# TEST_DATABASE_URL=postgres://app:app@localhost:5432/app_test?sslmode=disable
# TEST_VALKEY_URL=localhost:6379

# ──────────────────────────────────────────────────
# Optional: YAML config file path (overridden by env vars above)
# ──────────────────────────────────────────────────
# CONFIG_FILE=config.yaml
